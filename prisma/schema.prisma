generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(CUSTOMER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
}

model Account {
  id             Int           @id @default(autoincrement())
  accountNumber  String        @unique
  balance        Float         @default(0)
  type           AccountType   @default(SAVINGS)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  userId         Int
  user           User          @relation(fields: [userId], references: [id])
  sentTransactions     Transaction[] @relation("SenderAccount")
  receivedTransactions Transaction[] @relation("ReceiverAccount")
}

model Transaction {
  id            Int             @id @default(autoincrement())
  type          TransactionType
  amount        Float
  description   String?
  createdAt     DateTime        @default(now())
  fromAccountId Int?
  toAccountId   Int?
  fromAccount   Account? @relation("SenderAccount", fields: [fromAccountId], references: [id])
  toAccount     Account? @relation("ReceiverAccount", fields: [toAccountId], references: [id])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum AccountType {
  SAVINGS
  CHECKING
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}